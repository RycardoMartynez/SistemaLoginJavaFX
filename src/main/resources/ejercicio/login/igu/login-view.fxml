<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="950.0" style="-fx-background-color: #f5f6fa;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ejercicio.login.igu.LoginController">
    <children>

        <HBox alignment="CENTER" spacing="30.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>

                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label style="-fx-text-fill: #9ca3af; -fx-font-size: 10px;" text="TodoCode — Desafío Mensual Nº 5" />

                        <VBox maxWidth="350.0" prefWidth="350.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 20, 0, 0, 4);">
                            <children>
                                <Region prefHeight="6.0" style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); -fx-background-radius: 16 16 0 0;" />
                                <VBox spacing="20.0">
                                    <padding>
                                        <Insets bottom="25.0" left="30.0" right="30.0" top="20.0" />
                                    </padding>
                                    <children>
                                        <VBox alignment="CENTER" spacing="5.0">
                                            <children>
                                                <Label style="-fx-font-size: 28px;" text="🔐" />
                                                <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;" text="Iniciar Sesión" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="15.0">
                                            <children>
                                                <VBox spacing="5.0">
                                                    <children>
                                                        <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;" text="Usuario" />
                                                        <TextField fx:id="txtUsuario" promptText="Tu usuario" style="-fx-background-color: #f9fafb; -fx-border-color: #e5e7eb; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 8;" />
                                                    </children>
                                                </VBox>
                                                <VBox spacing="5.0">
                                                    <children>
                                                        <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;" text="Contraseña" />
                                                        <PasswordField fx:id="txtContrasena" promptText="••••••••" style="-fx-background-color: #f9fafb; -fx-border-color: #e5e7eb; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 8;" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                        <HBox spacing="10.0">
                                            <children>
                                                <Button fx:id="btnLimpiar" maxWidth="Infinity" onAction="#limpiar" prefHeight="35.0" style="-fx-background-color: #f3f4f6; -fx-text-fill: #6b7280; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-cursor: hand;" text="Limpiar" HBox.hgrow="ALWAYS" />
                                                <Button fx:id="btnLogin" maxWidth="Infinity" onAction="#Login" prefHeight="35.0" style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Ingresar" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                        <TextArea fx:id="txtResultado" editable="false" prefHeight="70.0" style="-fx-control-inner-background: #f9fafb; -fx-font-size: 12px;" wrapText="true" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox alignment="CENTER" spacing="10.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label style="-fx-text-fill: #9ca3af; -fx-font-size: 10px;" text="Panel de Administración de Usuarios" />

                        <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 20, 0, 0, 4);" VBox.vgrow="ALWAYS">
                            <children>
                                <Region prefHeight="6.0" style="-fx-background-color: linear-gradient(to right, #764ba2, #667eea); -fx-background-radius: 16 16 0 0;" />
                                <VBox spacing="15.0" VBox.vgrow="ALWAYS">
                                    <padding>
                                        <Insets bottom="25.0" left="25.0" right="25.0" top="20.0" />
                                    </padding>
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <children>
                                                <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;" text="👥 Listado de Usuarios" />
                                                <Region HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>

                                        <TableView fx:id="tablaUsuarios" prefHeight="300.0" style="-fx-background-color: transparent; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-background-radius: 8;" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colIde" prefWidth="60.0" text="ID" />
                                                <TableColumn fx:id="colUsu" prefWidth="150.0" text="Usuario" />
                                                <TableColumn fx:id="colRol" prefWidth="150.0" text="Rol" />
                                            </columns>
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                            </columnResizePolicy>
                                        </TableView>

                                        <HBox alignment="CENTER_RIGHT" spacing="15.0">
                                            <children>
                                                <Button fx:id="btnBorrar" onAction="#borrar" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #fee2e2; -fx-text-fill: #dc2626; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-border-color: #fecaca; -fx-border-radius: 8;" text="🗑 Borrar" />
                                                <Button fx:id="btnEditar" onAction="#AEditar" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #e0e7ff; -fx-text-fill: #4338ca; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-border-color: #c7d2fe; -fx-border-radius: 8;" text="✏️ Editar" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>

            </children>
        </HBox>
    </children>
</AnchorPane>
